# PostgreSQL Database Configuration
POSTGRES_USER=root
POSTGRES_PASSWORD=multipass
POSTGRES_DB=comapdb
POSTGRES_PORT=5432

# Database URL for application (don't change 'db' - it's the Docker service name)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:${POSTGRES_PORT}/${POSTGRES_DB}

# React App API Configuration
# For Docker: use '/api/' (proxied by nginx to the server service)
# For local development outside Docker: use 'http://localhost:8000/'
REACT_APP_API_URL=/api/
