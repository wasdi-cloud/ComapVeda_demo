# PostgreSQL Database Configuration
POSTGRES_USER=root
POSTGRES_PASSWORD=multipass
POSTGRES_DB=comapdb
POSTGRES_PORT=5432  # External port on host (change if there's a conflict)

# Database URL for application
# IMPORTANT: Always use port 5432 (internal container port), NOT ${POSTGRES_PORT}
# The server connects via Docker network, where PostgreSQL always runs on 5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# React App API Configuration
# For Traefik deployment: use relative path /api/ (same domain as frontend)
# Browser requests to https://comap.wasdi.net/api/* are routed by Traefik to backend
REACT_APP_API_URL=/api/
